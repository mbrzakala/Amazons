// Chat-centric Prisma schema for BuildWithAI.
//
// A single user Problem is solved by MULTIPLE independent methods (currently
// TRIZ + free-form Ideation), each producing its own Solution. Every Solution
// carries the agent's final advice AND the full reasoning trail (the ADK event
// trace: tool/MCP calls, their arguments and results, and model thoughts) so
// the "thinking process" is persisted, not just the answer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Problem {
  id                 String     @id @default(uuid())
  description        String     // User's problem description (the "IF")
  improvingParameter String     // What should improve (the "THEN")
  worseningParameter String     // What degrades as a result (the "BUT")
  createdAt          DateTime   @default(now())
  solutions          Solution[]
}

model Solution {
  id        String  @id @default(uuid())
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  method    String  // Resolution method that produced this proposition: 'triz' | 'ideation'
  advice    String  // The agent's final formatted response text (the proposition)

  // The "thinking process": normalized, ordered reasoning steps distilled from
  // the ADK event stream. Each step: { order, type, author, text?, toolName?, args?, response? }
  reasoningTrail Json?
  // The untouched ADK events array, kept for full fidelity / debugging.
  rawEvents      Json?

  // TRIZ-specific structured metadata (null for non-TRIZ methods).
  improvingParamId    Int?
  preservingParamId   Int?
  improvingParamName  String?
  preservingParamName String?
  principles          Json?   // Parsed TRIZ principles: { id, name, description }[]

  rating    Int?     // Per-proposition feedback rating (1-5 stars)
  createdAt DateTime @default(now())

  // Parsed discrete candidates from the agent's advice text.
  // Shape depends on method: TRIZ candidates have {id,title,principleId,principleName,description};
  // ideation candidates have {id,title,mechanism,whyItWorks,tradeoffs}.
  // Evaluation scores are merged into each candidate object by the evaluation step.
  candidates Json?

  @@index([problemId])
}
